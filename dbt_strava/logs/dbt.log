  create  table "airflow"."public_gold"."fct_weekly_summary__dbt_tmp"
  
  
    as
  
  (
    

with fct_daily as (
    select * from "airflow"."public_gold"."fct_daily_training_log"
),
dim_date as (
    select * from "airflow"."public_gold"."dim_date"
)

select
    d.year,
    d.week_number,
    min(d.date_day) as week_start_date,
    sum(f.total_runs) as total_runs,
    sum(f.total_distance_km) as total_distance_km,
    sum(f.total_moving_time_min) as total_moving_time_min,
    sum(f.total_elevation_m) as total_elevation_m,
    -- calculate weekly avg pace
    case 
        when sum(f.total_distance_km) > 0 
        then sum(f.total_moving_time_min) / sum(f.total_distance_km)
        else null 
    end as avg_pace_min_per_km
from dim_date d
left join fct_daily f on d.date_day = f.date_day
where d.date_day <= current_date
group by 1, 2
  );
  
[0m06:46:53.890504 [debug] [Thread-2 (]: On model.strava_analytics.training_load: /* {"app": "dbt", "dbt_version": "1.7.0", "profile_name": "strava_profile", "target_name": "dev", "node_id": "model.strava_analytics.training_load"} */

  
    

  create  table "airflow"."public_metrics"."training_load__dbt_tmp"
  
  
    as
  
  (
    

with daily as (
    select * from "airflow"."public_gold"."fct_daily_training_log"
),
rolling_avgs as (
    select
        date_day,
        total_distance_km as daily_distance,
        avg(total_distance_km) over (
            order by date_day
            rows between 41 preceding and current row
        ) as ctl_42d_avg,
        avg(total_distance_km) over (
            order by date_day
            rows between 6 preceding and current row
        ) as atl_7d_avg
    from daily
)

select
    date_day,
    daily_distance,
    ctl_42d_avg as ctl,
    atl_7d_avg as atl,
    (ctl_42d_avg - atl_7d_avg) as tsb
from rolling_avgs
  );
  
