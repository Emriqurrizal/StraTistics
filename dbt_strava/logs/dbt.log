[0m05:16:57.786301 [debug] [Thread-3 (]: On model.strava_analytics.stg_splits: /* {"app": "dbt", "dbt_version": "1.7.0", "profile_name": "strava_profile", "target_name": "dev", "node_id": "model.strava_analytics.stg_splits"} */

  create view "airflow"."public_silver"."stg_splits__dbt_tmp"
    
    
  as (
    

with laps as (
    select * from "airflow"."bronze"."raw_laps"
)

select
    strava_id,
    lap_index,
    distance / 1000.0 as lap_distance_km,
    elapsed_time,
    moving_time,
    case 
        when distance > 0 then (moving_time / 60.0) / (distance / 1000.0)
        else null 
    end as pace_min_per_km,
    average_heartrate,
    max_heartrate,
    average_cadence
from laps
  );
