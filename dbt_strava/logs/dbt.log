    as
  
  (
    

with fct_daily as (
    select * from "airflow"."public_gold"."fct_daily_training_log"
),
dim_date as (
    select * from "airflow"."public_gold"."dim_date"
)

select
    d.year,
    d.month,
    min(d.date_day) as month_start_date,
    sum(f.total_runs) as total_runs,
    sum(f.total_distance_km) as total_distance_km,
