[0m16:05:55.322547 [debug] [Thread-3 (]: On model.strava_analytics.stg_activities: /* {"app": "dbt", "dbt_version": "1.7.0", "profile_name": "strava_profile", "target_name": "dev", "node_id": "model.strava_analytics.stg_activities"} */

  create view "airflow"."public_silver"."stg_activities__dbt_tmp"
    
    
  as (
    

with raw as (
    select * from "airflow"."bronze"."raw_activities"
)

select
    strava_id,
    name,
    sport_type,
    start_date,
    -- Convert distance from meters to km
    distance / 1000.0 as distance_km,
    moving_time,
    elapsed_time,
    total_elevation_gain as elevation_m,
    -- Calculate pace in minutes per km
    case 
        when distance > 0 then (moving_time / 60.0) / (distance / 1000.0)
        else null 
    end as avg_pace_min_per_km,
    average_heartrate,
    max_heartrate,
    average_cadence,
    calories,
    gear_id,
    start_latlng,
    map_polyline,
    source,
    ingested_at
from raw
where sport_type in ('Run', 'TrailRun')
  );
